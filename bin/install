#!/bin/sh

set -e

if [ "$1" = '' ]; then
  >&2 printf 'usage: %s SOURCE_DIRECTORY\n' "$0"
  exit 1
fi

dir=${1%/}

# This path might be Ubuntu or Debian specific.
pico_prefix="/run/media/$USER/"
pico=$(find "$pico_prefix" -type d \( -name 'RPI-RP2' -o -name 'RP2350' \) | head -1)
if ! [ -e "$pico" ]; then
  >&2 printf 'Error: The expected mass storage location was not found under %s.\n' "$pico_prefix"
  >&2 printf 'Is the Pico in boot select mode?\n'
  exit 2
fi

uf2="$dir/build/$dir.uf2"
printf 'Copying %s to Pico mass storage device.\n' "$uf2"
cp "$uf2" "$pico"
